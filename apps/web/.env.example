# Environment Variables
# Copy this file to .env.local and fill in the values

# Course Completion NFT Contract Address (after deployment)
NEXT_PUBLIC_COURSE_COMPLETION_NFT_ADDRESS=

# Pinata IPFS JWT (get from https://pinata.cloud)
NEXT_PUBLIC_PINATA_JWT=

# WalletConnect Cloud project ID for wallet connections (required)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=4525818b4e7a741383c49e446010e7fd

# Application name displayed in wallet dialogs
NEXT_PUBLIC_APP_NAME=NSkills Course NFT

# Legacy ERC721 addresses (from original template)
NEXT_PUBLIC_NFT_ADDRESS=
PRIVATE_KEY=
ERC721_DEPLOYMENT_API_URL=http://localhost:4001